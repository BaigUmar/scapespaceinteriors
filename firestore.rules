rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == "umarbaig2006@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'displayName', 'createdAt']) &&
             data.email is string && data.email.size() <= 255 &&
             data.role in ['admin', 'customer'] &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.createdAt is string;
    }

    function isValidProject(data) {
      // Simplified validation to avoid hidden failures
      return data.title is string && data.title.size() <= 500 &&
             data.category is string &&
             data.description is string &&
             data.imageUrl is string &&
             data.status in ['public', 'draft'];
    }

    function isValidConsultation(data) {
      return data.keys().hasAll(['customerName', 'customerEmail', 'message', 'status', 'createdAt']) &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.customerEmail is string && data.customerEmail.size() <= 255 &&
             data.message is string && data.message.size() <= 5000 &&
             data.status in ['pending', 'contacted', 'completed'] &&
             data.createdAt is string;
    }

    function isValidIdea(data) {
      return data.title is string && 
             data.description is string &&
             data.price is number &&
             data.imageUrl is string &&
             data.category in ['home', 'kitchen', 'wardrobe'];
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == 'customer' || 
        incoming().email.lower() == 'umarbaig2006@gmail.com'
      );
      allow update: if (isOwner(userId) || isAdmin()) && (
        (isOwner(userId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) ||
          (incoming().email.lower() == 'umarbaig2006@gmail.com' && incoming().role == 'admin' && incoming().diff(existing()).affectedKeys().hasAny(['role']))
        ) && isValidUser(incoming())) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['role', 'displayName']) && isValidUser(incoming()))
      );
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /consultations/{requestId} {
      allow read: if isAdmin();
      allow create: if isValidConsultation(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin() && isValidConsultation(incoming());
      allow delete: if isAdmin();
    }

    match /ideas/{ideaId} {
      allow read: if true;
      allow create: if isAdmin() && isValidIdea(incoming());
      allow update: if isAdmin() && isValidIdea(incoming());
      allow delete: if isAdmin();
    }
  }
}
